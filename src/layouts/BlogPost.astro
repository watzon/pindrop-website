---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import screenshot from '../assets/images/screenshot.png';

interface Props {
  title: string;
  description: string;
  date: Date;
  version?: string;
  tags?: string[];
}

const { title, description, date, version, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": date.toISOString(),
  "dateModified": date.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "Pindrop",
    "url": Astro.site?.toString()
  },
  "publisher": {
    "@type": "Organization",
    "name": "Pindrop",
    "logo": {
      "@type": "ImageObject",
      "url": new URL('/favicon.svg', Astro.site).toString()
    }
  },
  "image": new URL(screenshot.src, Astro.site).toString(),
  "keywords": tags?.join(", ") || "Pindrop, dictation, AI, macOS"
};
---

<Layout title={`${title} - Pindrop Blog`} description={description} type="article" image={screenshot.src}>
<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

<Header />

<main class="pt-40 pb-20 px-6">
  <div class="max-w-3xl mx-auto">
    <a 
      href="/blog" 
      class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-text-primary transition-colors mb-12 group"
    >
      <div class="p-1.5 rounded-lg bg-surface border border-border group-hover:border-accent/30 transition-colors group-hover:-translate-x-1 duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </div>
      Back to Blog
    </a>

    <article>
      <header class="text-center mb-16 space-y-6">
        <div class="flex items-center justify-center gap-4 text-sm text-text-muted">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {version && (
            <span class="px-3 py-1 rounded-full bg-accent/10 text-accent border border-accent/20 text-xs font-mono font-medium">
              v{version}
            </span>
          )}
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-semibold text-dark leading-[1.1] tracking-tight">
          {title}
        </h1>
        
        <p class="text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
          {description}
        </p>
      </header>
      
      <div class="blog-content">
        <slot />
      </div>
    </article>
  </div>
</main>

<Footer />
</Layout>

<style>
  @reference "../styles/global.css";
  
  .blog-content {
    @apply text-lg text-text-secondary leading-relaxed;
  }

  .blog-content :global(h2) {
    @apply text-2xl md:text-3xl font-display font-semibold text-dark mt-16 mb-6 scroll-mt-32;
  }

  .blog-content :global(h3) {
    @apply text-xl md:text-2xl font-display font-semibold text-dark mt-10 mb-4 scroll-mt-32;
  }

  .blog-content :global(p) {
    @apply mb-6;
  }

  .blog-content :global(ul) {
    @apply list-disc list-outside ml-6 mb-8 space-y-2;
  }

  .blog-content :global(ol) {
    @apply list-decimal list-outside ml-6 mb-8 space-y-2;
  }

  .blog-content :global(li) {
    @apply pl-2 marker:text-accent;
  }

  .blog-content :global(a) {
    @apply text-accent hover:text-accent-dark transition-colors underline decoration-accent/30 hover:decoration-accent underline-offset-4;
  }

  .blog-content :global(strong) {
    @apply text-dark font-semibold;
  }

  .blog-content :global(blockquote) {
    @apply border-l-4 border-accent/50 pl-6 py-1 my-8 italic text-text-muted bg-surface rounded-r-lg;
  }

  .blog-content :global(code) {
    @apply font-mono text-sm bg-surface text-accent px-1.5 py-0.5 rounded border border-border;
  }

  .blog-content :global(pre) {
    @apply bg-dark p-6 rounded-xl border border-border/50 overflow-x-auto mb-8 text-sm leading-relaxed;
  }

  .blog-content :global(pre code) {
    @apply bg-transparent p-0 text-cream border-none text-sm;
  }

  .blog-content :global(img) {
    @apply rounded-xl border border-border shadow-md my-8 w-full h-auto;
  }

  .blog-content :global(hr) {
    @apply border-border my-12;
  }
</style>
