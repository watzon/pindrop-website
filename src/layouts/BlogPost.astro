---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';

interface Props {
  id?: string;
  title: string;
  description: string;
  date: Date;
  version?: string;
  tags?: string[];
}

const { id, title, description, date, version, tags } = Astro.props;

// Derive OG image URL from post id if available, otherwise fall back to home OG
const ogImage = id ? `/og/blog/${id}.png` : undefined;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": date.toISOString(),
  "dateModified": date.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "Pindrop",
    "url": Astro.site?.toString()
  },
  "publisher": {
    "@type": "Organization",
    "name": "Pindrop",
    "logo": {
      "@type": "ImageObject",
      "url": new URL('/favicon.svg', Astro.site).toString()
    }
  },
  "keywords": tags?.join(", ") || "Pindrop, dictation, AI, macOS"
};
---

<Layout title={`${title} — Pindrop Blog`} description={description} type="article" image={ogImage}>
<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

<Header />

<main class="pt-32 pb-24 px-6">
  <div class="max-w-3xl mx-auto">

    <!-- Back link -->
    <a
      href="/blog"
      class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-text-primary transition-colors duration-200 mb-14 group"
    >
      <div class="w-7 h-7 rounded-full bg-surface border border-border flex items-center justify-center group-hover:border-border-strong group-hover:-translate-x-0.5 transition-all duration-200">
        <Icon name="chevron-right" size={13} class="rotate-180" />
      </div>
      Back to Blog
    </a>

    <article>

      <!-- Article header -->
      <header class="mb-16 space-y-6">
        <div class="flex flex-wrap items-center gap-3">
          <time datetime={date.toISOString()} class="text-sm font-mono text-text-muted">
            {formattedDate}
          </time>
          {version && (
            <span class="text-xs font-mono font-medium px-2.5 py-0.5 rounded-full bg-accent-subtle text-accent border border-accent/20">
              v{version}
            </span>
          )}
          {tags?.map(tag => (
            <span class="text-xs font-medium px-2.5 py-0.5 rounded-full bg-surface border border-border text-text-muted">
              {tag}
            </span>
          ))}
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-[3.25rem] font-bold tracking-tight text-text-primary leading-[1.07]">
          {title}
        </h1>

        <p class="text-lg md:text-xl text-text-secondary leading-relaxed">
          {description}
        </p>

        <div class="divider"></div>
      </header>

      <!-- Post body -->
      <div class="blog-content">
        <slot />
      </div>

    </article>
  </div>
</main>

<Footer />
</Layout>

<style>
  @reference "../styles/global.css";

  .blog-content {
    @apply text-base md:text-lg text-text-secondary leading-relaxed;
  }

  .blog-content :global(h2) {
    @apply text-2xl md:text-3xl font-bold tracking-tight text-text-primary mt-16 mb-5 scroll-mt-32;
  }

  .blog-content :global(h3) {
    @apply text-xl md:text-2xl font-bold tracking-tight text-text-primary mt-10 mb-4 scroll-mt-32;
  }

  .blog-content :global(h4) {
    @apply text-lg font-semibold text-text-primary mt-8 mb-3 scroll-mt-32;
  }

  .blog-content :global(p) {
    @apply mb-6;
  }

  .blog-content :global(ul) {
    @apply list-disc list-outside ml-6 mb-8 space-y-2;
  }

  .blog-content :global(ol) {
    @apply list-decimal list-outside ml-6 mb-8 space-y-2;
  }

  .blog-content :global(li) {
    @apply pl-2;
  }

  .blog-content :global(a) {
    @apply text-accent hover:text-accent-dark transition-colors underline decoration-accent/30 hover:decoration-accent underline-offset-4;
  }

  .blog-content :global(strong) {
    @apply text-text-primary font-semibold;
  }

  .blog-content :global(em) {
    @apply italic;
  }

  .blog-content :global(blockquote) {
    @apply border-l-2 border-accent/40 pl-6 my-8 text-text-muted italic;
  }

  .blog-content :global(code) {
    @apply font-mono text-sm bg-surface text-accent px-1.5 py-0.5 rounded-md border border-border;
  }

  .blog-content :global(pre) {
    @apply bg-dark rounded-2xl p-6 border border-dark-border overflow-x-auto mb-8 text-sm leading-relaxed;
  }

  .blog-content :global(pre code) {
    @apply bg-transparent p-0 text-dark-text border-none text-sm;
  }

  .blog-content :global(img) {
    @apply rounded-2xl border border-border shadow-md my-8 w-full h-auto;
  }

  .blog-content :global(hr) {
    @apply border-border my-12;
  }

  .blog-content :global(table) {
    @apply w-full text-sm border-collapse mb-8;
  }

  .blog-content :global(th) {
    @apply text-left font-semibold text-text-primary p-3 border-b border-border bg-surface;
  }

  .blog-content :global(td) {
    @apply p-3 border-b border-border text-text-secondary;
  }
</style>
