---
import Icon from './Icon.astro';

interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  icon?: string;
  external?: boolean;
  class?: string;
  size?: 'sm' | 'md' | 'lg';
  'data-download-trigger'?: string;
}

const { 
  href, 
  variant = 'primary', 
  icon, 
  external = false,
  class: className = '',
  size = 'md',
  'data-download-trigger': downloadTrigger
} = Astro.props;

const baseStyles = "inline-flex items-center justify-center font-medium rounded-lg transition-all duration-300 ease-out focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-cream";

const variantStyles = {
  primary: "bg-dark text-cream hover:bg-dark-surface shadow-sm hover:shadow-md",
  secondary: "bg-surface text-text-primary border border-border hover:bg-border hover:border-text-muted",
  ghost: "text-text-secondary hover:text-text-primary hover:bg-surface"
};

const sizeStyles = {
  sm: "text-sm px-4 py-2 gap-2",
  md: "text-base px-5 py-2.5 gap-2",
  lg: "text-lg px-7 py-3.5 gap-2.5"
};

const combinedClass = `${baseStyles} ${variantStyles[variant]} ${sizeStyles[size]} ${className}`;
---

<a 
  href={href} 
  class={combinedClass}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  data-download-trigger={downloadTrigger}
  onclick={downloadTrigger ? `event.preventDefault(); window.openDownloadModal('${downloadTrigger}')` : undefined}
>
  {icon && <Icon name={icon as any} size={size === 'sm' ? 16 : size === 'md' ? 18 : 22} />}
  <slot />
</a>
