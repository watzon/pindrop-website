---
import Button from './Button.astro';
import Icon from './Icon.astro';
---

<div id="download-modal" class="fixed inset-0 z-[100] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">

  <!-- Backdrop -->
  <div
    id="modal-backdrop"
    class="absolute inset-0 bg-dark/70 backdrop-blur-sm transition-opacity duration-300 opacity-0"
  ></div>

  <!-- Panel -->
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div
      id="modal-panel"
      class="relative w-full max-w-xl transform transition-all duration-300 scale-95 opacity-0"
    >
      <!-- Outer bezel -->
      <div class="p-0.5 bg-white/8 border border-white/10 rounded-[2rem] shadow-[0_32px_80px_rgba(0,0,0,0.5)]">
        <!-- Inner card -->
        <div class="relative overflow-hidden rounded-[calc(2rem-2px)] bg-dark-surface">

          <!-- Ambient blobs (fixed, pointer-events-none) -->
          <div class="absolute -top-20 -right-20 w-56 h-56 bg-brand-orange/20 rounded-full blur-[60px] pointer-events-none"></div>
          <div class="absolute -bottom-20 -left-20 w-56 h-56 bg-brand-pink/20 rounded-full blur-[60px] pointer-events-none"></div>

          <!-- Close -->
          <button
            id="modal-close"
            class="absolute top-4 right-4 p-2 rounded-full text-dark-muted hover:text-dark-text hover:bg-white/6 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
            aria-label="Close"
          >
            <Icon name="x" size={18} />
          </button>

          <div class="relative z-10 p-8 md:p-10 space-y-8 text-center">

            <!-- Header -->
            <div class="space-y-2">
              <p class="tag mx-auto w-fit">Download started</p>
              <h2 id="modal-title" class="text-3xl md:text-4xl font-bold text-dark-text tracking-tight">
                Thanks for trying Pindrop
              </h2>
              <p class="text-dark-muted">
                Your download should begin automatically.
              </p>
            </div>

            <!-- Cards -->
            <div class="grid md:grid-cols-2 gap-4 text-left">

              <!-- GitHub star -->
              <div class="p-0.5 bg-white/4 border border-white/8 rounded-[1.5rem] hover:border-brand-orange/30 transition-colors duration-300">
                <div class="rounded-[calc(1.5rem-2px)] bg-dark-2 p-6 space-y-4 flex flex-col h-full">
                  <div class="w-11 h-11 rounded-2xl bg-white/6 border border-white/8 flex items-center justify-center text-dark-text">
                    <Icon name="github" size={22} />
                  </div>
                  <div class="flex-1 space-y-1.5">
                    <h3 class="text-base font-semibold text-dark-text">Star on GitHub</h3>
                    <p class="text-sm text-dark-muted leading-relaxed">
                      Give us a star to help others discover the project.
                    </p>
                  </div>
                  <a
                    href="https://github.com/watzon/pindrop"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center gap-2 w-full py-2.5 rounded-full bg-white/8 border border-white/10 text-sm font-medium text-dark-text hover:bg-white/12 transition-colors"
                  >
                    <Icon name="github" size={16} />
                    Star Project
                  </a>
                </div>
              </div>

              <!-- Sponsor -->
              <div class="p-0.5 bg-white/4 border border-white/8 rounded-[1.5rem] hover:border-brand-pink/30 transition-colors duration-300">
                <div class="rounded-[calc(1.5rem-2px)] bg-dark-2 p-6 space-y-4 flex flex-col h-full">
                  <div class="w-11 h-11 rounded-2xl bg-linear-to-br from-brand-orange to-brand-pink flex items-center justify-center text-white">
                    <Icon name="heart" size={20} />
                  </div>
                  <div class="flex-1 space-y-1.5">
                    <h3 class="text-base font-semibold text-dark-text">Support Development</h3>
                    <p class="text-sm text-dark-muted leading-relaxed">
                      Help sustain ongoing work and new features.
                    </p>
                  </div>
                  <div class="space-y-2">
                    <a
                      href="https://github.com/sponsors/watzon"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center justify-center gap-2 w-full py-2.5 rounded-full bg-linear-to-r from-brand-orange to-brand-pink text-sm font-semibold text-white hover:opacity-90 transition-opacity"
                    >
                      <Icon name="heart" size={16} />
                      GitHub Sponsors
                    </a>
                    <a
                      href="https://ko-fi.com/watzon"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block text-center text-xs text-dark-muted hover:text-dark-text transition-colors"
                    >
                      Or donate via Ko-Fi &rarr;
                    </a>
                  </div>
                </div>
              </div>

            </div>

            <!-- Dismiss -->
            <button
              id="modal-dismiss"
              class="text-sm text-dark-muted hover:text-dark-text transition-colors"
            >
              No thanks, just the download
            </button>

          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function getEls() {
    return {
      modal:    document.getElementById('download-modal'),
      backdrop: document.getElementById('modal-backdrop'),
      panel:    document.getElementById('modal-panel'),
    };
  }

  function openDownloadModal(url: string) {
    const { modal, backdrop, panel } = getEls();
    if (!modal || !backdrop || !panel) return;

    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    requestAnimationFrame(() => {
      backdrop.classList.remove('opacity-0');
      panel.classList.remove('scale-95', 'opacity-0');
      panel.classList.add('scale-100', 'opacity-100');
    });

    const link = document.createElement('a');
    link.href = url;
    link.target = '_blank';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }

  function closeDownloadModal() {
    const { modal, backdrop, panel } = getEls();
    if (!modal || !backdrop || !panel) return;

    backdrop.classList.add('opacity-0');
    panel.classList.remove('scale-100', 'opacity-100');
    panel.classList.add('scale-95', 'opacity-0');

    setTimeout(() => {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }, 300);
  }

  declare global {
    interface Window { openDownloadModal: (url: string) => void; }
  }
  window.openDownloadModal = openDownloadModal;

  function setupListeners() {
    const modal = document.getElementById('download-modal');
    const closeBtn = document.getElementById('modal-close');
    const dismissBtn = document.getElementById('modal-dismiss');

    if (closeBtn)  closeBtn.onclick  = closeDownloadModal;
    if (dismissBtn) dismissBtn.onclick = closeDownloadModal;
    if (modal) modal.onclick = (e) => { if (e.target === modal) closeDownloadModal(); };
  }

  document.addEventListener('astro:page-load', setupListeners);
  document.addEventListener('keydown', (e) => {
    const modal = document.getElementById('download-modal');
    if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
      closeDownloadModal();
    }
  });
</script>
