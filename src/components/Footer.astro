---
import Icon from './Icon.astro';
import pindropLogo from '../assets/pindrop-logo.svg';

const currentYear = new Date().getFullYear();
---

<footer class="py-16 px-6 border-t border-border bg-cream">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="flex flex-col items-center md:items-start gap-4">
        <a href="/" class="flex items-center gap-2">
          <img src={pindropLogo.src} alt="" width="20" height="20" />
          <span class="font-display font-semibold text-lg">Pindrop</span>
        </a>
        <p class="text-sm text-text-muted">
          &copy; {currentYear} Pindrop. Open source under MIT License.
        </p>
      </div>

      <div class="flex items-center gap-6">
        <a href="/blog" class="text-sm text-text-secondary hover:text-text-primary transition-colors">
          Blog
        </a>
        <a href="https://github.com/watzon/pindrop" class="text-text-secondary hover:text-text-primary transition-colors" aria-label="GitHub">
          <Icon name="github" size={20} />
        </a>
        <a href="https://github.com/watzon/pindrop/discussions" class="text-sm text-text-secondary hover:text-text-primary transition-colors">
          Discussions
        </a>
        <a href="https://github.com/watzon/pindrop/blob/main/LICENSE" class="text-sm text-text-secondary hover:text-text-primary transition-colors">
          License
        </a>
      </div>

      <div class="text-sm text-text-muted flex items-center gap-2">
        <span>Built with</span>
        <span class="text-text-secondary">WhisperKit</span>
        <span>&amp;</span>
        <span class="text-text-secondary">SwiftUI</span>
      </div>
    </div>
  </div>
</footer>
