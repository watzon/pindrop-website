---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const title = "Blog & Changelog";
const description = "Release notes, updates, and announcements for Pindrop.";
---

<Layout title={title} description={description}>
   <Header />

   <main class="pt-40 pb-20 px-6">
    <div class="max-w-6xl mx-auto">
      <header class="text-center mb-20 space-y-6">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-semibold text-dark leading-[1.1] tracking-tight">
          Blog & Changelog
        </h1>
        <p class="text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
          Release notes, updates, and announcements.
        </p>
      </header>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="group block">
            <article class="h-full p-8 rounded-2xl bg-surface border border-border hover:border-accent/30 transition-all duration-500">
              <div class="flex items-center justify-between mb-4">
                <time datetime={post.data.date.toISOString()} class="text-sm text-text-muted font-mono">
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                {post.data.version && (
                  <span class="px-2 py-0.5 rounded-full bg-accent/10 text-accent border border-accent/20 text-xs font-mono font-medium">
                    v{post.data.version}
                  </span>
                )}
              </div>
              
              <h2 class="text-2xl font-display font-semibold text-dark mb-3 group-hover:text-accent transition-colors leading-tight">
                {post.data.title}
              </h2>
              
              <p class="text-text-secondary mb-6 line-clamp-3 leading-relaxed">
                {post.data.description}
              </p>
              
              <div class="flex items-center text-sm font-medium text-accent mt-auto group-hover:translate-x-1 transition-transform duration-300">
                Read more <span class="ml-1">&rarr;</span>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
