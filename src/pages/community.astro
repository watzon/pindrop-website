---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';

const resources = [
  {
    icon: 'github',
    title: 'GitHub Repository',
    description: 'Browse the source, open pull requests, and track the roadmap.',
    link: 'https://github.com/watzon/pindrop',
    cta: 'View Repository',
  },
  {
    icon: 'sparkles',
    title: 'GitHub Discussions',
    description: 'Ask questions, share ideas, and get help from other users.',
    link: 'https://github.com/watzon/pindrop/discussions',
    cta: 'Join Discussion',
  },
  {
    icon: 'shield',
    title: 'Issue Tracker',
    description: 'Found a bug? Report it so we can fix it in the next release.',
    link: 'https://github.com/watzon/pindrop/issues',
    cta: 'Report Issue',
  },
];

const faqItems = [
  {
    question: 'Does Pindrop work on Intel Macs?',
    answer: 'Yes, Pindrop runs on Intel Macs, but it\'s highly optimized for Apple Silicon (M1 and later) via the Neural Engine. Intel users will see good performance with the smaller models.'
  },
  {
    question: 'Is my data sent anywhere?',
    answer: 'Transcription is 100% local — your voice never leaves your Mac. Optional AI enhancement can be configured to use external services (OpenAI, OpenRouter) or kept local with Ollama or LM Studio. You control where data goes.'
  },
  {
    question: 'What languages are supported?',
    answer: 'Pindrop currently performs best in English. Whisper models do support many languages, and we\'re working on first-class multi-language support in upcoming releases.'
  },
  {
    question: 'How is this different from macOS Dictation?',
    answer: 'macOS Dictation sends audio to Apple\'s servers unless you have Enhanced Dictation enabled. Pindrop is always offline-first, supports much larger and more accurate Whisper models, includes transcription history, custom vocabulary, AI enhancement, and is fully open source.'
  },
  {
    question: 'Can I contribute?',
    answer: 'Absolutely. Pindrop is MIT-licensed and welcomes contributions of all kinds — bug fixes, new features, documentation, and translations. Check out the Contributing Guide on GitHub to get started.'
  },
];
---

<Layout title="Community & Support — Pindrop">
  <Header />

  <main class="pt-32 pb-24 px-6">
    <div class="max-w-6xl mx-auto space-y-32">

      <!-- Hero -->
      <section class="max-w-2xl space-y-5 animate-fade-up">
        <p class="tag">Community</p>
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-text-primary leading-[1.06]">
          Built together,<br />used by everyone
        </h1>
        <p class="text-xl text-text-secondary leading-relaxed">
          Pindrop is open source and community-driven. Get help, report issues,
          and shape what comes next.
        </p>
      </section>

      <!-- Resources — horizontal list, no 3-col card grid -->
      <section>
        <h2 class="text-xs uppercase tracking-widest font-semibold text-text-muted mb-8 reveal">Get involved</h2>
        <div class="divide-y divide-border border-t border-b border-border">
          {resources.map((r, i) => (
            <a
              href={r.link}
              target="_blank"
              rel="noopener noreferrer"
              class={`group flex items-center justify-between gap-6 py-7 hover:bg-surface/40 -mx-6 px-6 transition-colors duration-200 reveal delay-${i + 1}`}
            >
              <div class="flex items-start gap-5">
                <div class="w-10 h-10 shrink-0 rounded-xl bg-surface border border-border text-accent flex items-center justify-center group-hover:bg-accent-subtle group-hover:border-accent/20 transition-colors duration-300">
                  <Icon name={r.icon as any} size={18} />
                </div>
                <div>
                  <h3 class="font-semibold text-text-primary mb-1 group-hover:text-accent transition-colors duration-200">{r.title}</h3>
                  <p class="text-sm text-text-secondary">{r.description}</p>
                </div>
              </div>
              <div class="flex items-center gap-2 shrink-0 text-sm font-medium text-text-muted group-hover:text-accent transition-colors duration-200">
                <span class="hidden sm:inline">{r.cta}</span>
                <Icon name="arrow-right" size={16} />
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Contributing CTA -->
      <section class="reveal">
        <div class="p-0.5 bg-black/4 border border-border rounded-[2rem]">
          <div class="bg-dark rounded-[calc(2rem-2px)] px-8 md:px-12 py-12 flex flex-col md:flex-row items-center justify-between gap-8 shadow-[inset_0_1px_0_rgba(255,255,255,0.06)]">
            <div class="space-y-3 max-w-lg text-center md:text-left">
              <h2 class="text-2xl md:text-3xl font-bold text-dark-text tracking-tight">
                Want to contribute?
              </h2>
              <p class="text-dark-muted leading-relaxed">
                We welcome bug fixes, new features, documentation, and translations.
                Read the contributing guide to get oriented quickly.
              </p>
            </div>
            <div class="flex flex-col sm:flex-row gap-3 shrink-0">
              <a
                href="https://github.com/watzon/pindrop/blob/main/CONTRIBUTING.md"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 bg-cream text-dark font-semibold px-6 py-3 rounded-full hover:bg-cream-dark transition-all duration-200 active:scale-[0.97] text-sm"
              >
                <Icon name="github" size={16} />
                Contributing Guide
              </a>
              <a
                href="https://github.com/watzon/pindrop/blob/main/CODE_OF_CONDUCT.md"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 border border-white/12 text-dark-text font-medium px-6 py-3 rounded-full hover:bg-white/6 transition-all duration-200 active:scale-[0.97] text-sm"
              >
                Code of Conduct
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="max-w-3xl">
        <div class="mb-10 reveal">
          <p class="tag mb-4">Common questions</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-text-primary">
            Frequently asked
          </h2>
        </div>

        <div class="space-y-0 divide-y divide-border border-t border-border">
          {faqItems.map((item, i) => (
            <details class={`group reveal delay-${i + 1}`}>
              <summary class="flex items-center justify-between gap-4 py-5 cursor-pointer list-none select-none">
                <h3 class="font-semibold text-text-primary text-base">{item.question}</h3>
                <div class="w-7 h-7 shrink-0 rounded-full bg-surface border border-border flex items-center justify-center text-text-muted group-open:rotate-90 transition-transform duration-200">
                  <Icon name="chevron-right" size={14} />
                </div>
              </summary>
              <div class="pb-6">
                <p class="text-text-secondary leading-relaxed text-sm">{item.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </section>

    </div>
  </main>

  <Footer />
</Layout>
